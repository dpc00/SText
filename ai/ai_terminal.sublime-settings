{
    // ai_terminal — ConPTY terminal for Sublime Text (currently Claude Code).
    // Edit this file to retune without source edits; changes apply live
    // (no plugin reload needed): the history deque is swapped in place and
    // the resize poller picks up new column bounds within ~750ms.

    // Number of lines kept in scrollback history (the `history` deque).
    // This is the minimap-fill knob: at font 14 / 685px viewport, 300 fills
    // the minimap. Retune by eye against the minimap when you change the
    // window height or font size. Decreasing it may improve performance.
    // Live: changing this swaps the live deque (trims oldest if smaller).
    "scrollback_history_size": 300,

    // Floor and ceiling on the auto-sized terminal width in characters.
    // cols is computed from the viewport width; min_columns is the lower
    // bound, max_columns caps it (null = no cap). The renderer's no-horizontal-
    // scrollbar math (cols = int(usable_w/cw) - 3) still applies inside these
    // bounds. Live: the resize poller picks up new bounds within ~750ms.
    "min_columns": 20,
    "max_columns": null
}