{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "gemini-log-hook",
            "type": "command",
            "command": "python .gemini/hooks/gemini_log_hook.py",
            "description": "Forwards Gemini CLI events to a local logging server."
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "gemini-log-hook",
            "type": "command",
            "command": "python .gemini/hooks/gemini_log_hook.py",
            "description": "Forwards Gemini CLI events to a local logging server."
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "gemini-log-hook",
            "type": "command",
            "command": "python .gemini/hooks/gemini_log_hook.py",
            "description": "Forwards Gemini CLI events to a local logging server."
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "gemini-log-hook",
            "type": "command",
            "command": "python .gemini/hooks/gemini_log_hook.py",
            "description": "Forwards Gemini CLI events to a local logging server."
          }
        ]
      }
    ]
  }
}